# Copy this file to .env and fill in a strong secret.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# Optional. Only set NODE_ENV=production when you are actually serving HTTPS,
# because 'secure' cookies are only sent over HTTPS.
# NODE_ENV=production

# Optional. Defaults to 3000.
# PORT=3000
